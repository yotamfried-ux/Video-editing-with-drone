SUPABASE_URL=https://bcndgmymnismbxvdeetc.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_CUSTOMER_CODE=
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
MESHULAM_API_KEY=
MESHULAM_WEBHOOK_SECRET=
MESHULAM_USER_ID=
# Operator secret — must match the value entered once in the mobile app's
# Operator settings. Authorizes pricing/support/analytics/operator routes.
OPERATOR_SECRET=
# Upstash Redis (rate limiting). If unset, rate limiting is disabled (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# GitHub dispatch — allows operator to trigger the pipeline from the mobile app.
# Fine-grained PAT with Actions:write on this repo.
GITHUB_DISPATCH_TOKEN=github_pat_...
GITHUB_REPO=yotamfried-ux/Video-editing-with-drone
# Resend transactional email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
# Google Drive — service account JSON (single line) + folder IDs.
# RAW_FOLDER_ID is required by /api/operator/upload.
GOOGLE_SERVICE_ACCOUNT_JSON=
RAW_FOLDER_ID=
REVIEW_FOLDER_ID=
APPROVED_FOLDER_ID=
# Public app domain for share/checkout redirect URLs
NEXT_PUBLIC_APP_DOMAIN=sportreel.app
