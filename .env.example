GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-pro
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
RAW_FOLDER_ID=your_raw_folder_id
CLIPS_FOLDER_ID=your_clips_folder_id
PROCESSED_FOLDER_ID=your_processed_folder_id
REVIEW_FOLDER_ID=your_review_folder_id
APPROVED_FOLDER_ID=your_approved_folder_id
OWNER_EMAIL=you@yourdomain.com
NOTIFY_EMAIL=fallback_client@email.com
LOGO_PATH=assets/logo.png
MUSIC_DIR=music
TMP_DIR=/tmp/dtor

# ── Sentry error monitoring (optional) — leave SENTRY_DSN empty to disable ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
