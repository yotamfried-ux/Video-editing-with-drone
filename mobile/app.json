{
  "expo": {
    "name": "SportReel",
    "slug": "sportreel",
    "version": "1.0.0",
    "scheme": "sportreel",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sportreel.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture your face photo for highlight reel matching.",
        "NSPhotoLibraryUsageDescription": "Used to select a face photo for highlight reel matching.",
        "NSFaceIDUsageDescription": "Used to secure operator access."
      }
    },
    "android": {
      "package": "com.sportreel.app",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-screen-capture",
      ["expo-local-authentication", { "faceIDPermission": "Used to secure operator access." }],
      "expo-font",
      ["expo-build-properties", { "android": { "kotlinVersion": "1.9.25" } }],
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#5B6EF5"
        }
      ],
      "./plugins/withCrashReporter"
    ],
    "updates": {
      "url": "https://u.expo.dev/5c03988f-3dae-4763-953a-672717dedda2",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "experiments": { "typedRoutes": true },
    "owner": "yotam102",
    "extra": {
      "eas": { "projectId": "5c03988f-3dae-4763-953a-672717dedda2" }
    }
  }
}
