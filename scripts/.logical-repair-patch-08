+def _cluster_outcome(
+    rows: list[dict[str, Any]],
+    selected: list[dict[str, Any]],
+    no_output_reason: str | None,
+) -> str:
+    if any(row.get("uploaded_to_review") or row.get("review_draft_name") for row in rows):
